# ===== 服务配置 =====
PORT=3000
# 部署后填你的公网地址，用于拼接邮箱验证链接，例如 https://lu.example.com
APP_URL=http://localhost:3000
# JWT 签名密钥，部署时务必改成一段随机长字符串（可用：openssl rand -hex 32）
JWT_SECRET=change_me_to_a_long_random_string

# ===== Gmail SMTP 发信 =====
# 你的 Gmail 地址
SMTP_USER=youraccount@gmail.com
# Gmail「应用专用密码」(16 位)，不是登录密码。
# 生成方式：Google 账号 -> 安全性 -> 开启两步验证 -> 应用专用密码
SMTP_PASS=xxxxxxxxxxxxxxxx
# 发件人显示名
MAIL_FROM_NAME=撸还是不撸

# ===== 每日提醒 =====
# 每天几点提醒还没做决定的人，cron 格式：分 时 日 月 周
REMINDER_CRON=0 21 * * *
# 提醒使用的时区（IANA 名）。不填则用服务器本地时区——很多云主机默认 UTC，强烈建议显式指定。
REMINDER_TZ=Asia/Shanghai
