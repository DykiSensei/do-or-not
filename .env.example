# ===== 服务配置 =====
PORT=3000
# 部署后填你的公网地址，用于拼接邮箱验证链接，例如 https://lu.example.com
APP_URL=http://localhost:3000
# JWT 签名密钥，部署时务必改成一段随机长字符串（可用：openssl rand -hex 32）
JWT_SECRET=change_me_to_a_long_random_string

# ===== Gmail SMTP 发信 =====
# 你的 Gmail 地址
SMTP_USER=youraccount@gmail.com
# Gmail「应用专用密码」(16 位)，不是登录密码。
# 生成方式：Google 账号 -> 安全性 -> 开启两步验证 -> 应用专用密码
SMTP_PASS=xxxxxxxxxxxxxxxx
# 发件人显示名
MAIL_FROM_NAME=撸还是不撸

# ===== 每日提醒 =====
# 各用户在自己时区的几点收提醒（24 小时制整数）。
# 用户时区在第一次决定时根据 IP 自动检测并落库，没检测到就回退到 Asia/Shanghai。
REMINDER_HOUR=21

# ===== Cloudflare Turnstile（注册接口防刷）=====
# 部署时去 https://dash.cloudflare.com -> Turnstile -> Add site，
# 拿到 Site Key + Secret Key 替换下面两行。
# 留空则禁用验证码（但注册接口就会再次裸奔，不推荐线上这么干）。
# 下面这对是 Cloudflare 官方测试密钥：永远验证通过，方便本地开发。
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
